# ═══════════════════════════════════════════════
# BROTOCHONDRIA — Discord Server Extraction Engine
# ═══════════════════════════════════════════════

# Discord Bot Token (from Developer Portal → Bot → Reset Token)
BOT_TOKEN=your_bot_token_here

# Server ID (right-click server name → Copy Server ID)
GUILD_ID=your_server_id_here

# Your User ID (right-click your name → Copy User ID)
# Progress updates sent to your DMs ONLY
OWNER_USER_ID=your_user_id_here

# Channel IDs to skip (comma-separated, leave empty for all)
SKIP_CHANNELS=

# Extraction Settings
PARALLEL_CHANNELS=10
MAX_FILE_SIZE_MB=100
MAX_CONCURRENT_DOWNLOADS=5

# Date Range (optional, ISO format e.g. 2023-01-01, leave empty for full history)
EXTRACT_AFTER_DATE=
EXTRACT_BEFORE_DATE=

# Google Drive folder name for the archive
GDRIVE_FOLDER_NAME=ServerName_Archive

# Local paths
OUTPUT_DIR=./output
TEMP_DIR=./temp
